# === Required ===
OPENAI_API_KEY=sk-proj-your-key-here

# === Optional — enables extra features ===
# ElevenLabs: voiceover narration + background music
ELEVENLABS_API_KEY=your-elevenlabs-key-here

# Upload Post: publish directly to Instagram
UPLOADPOST_API_KEY=your-uploadpost-key-here

# === Cloud storage (optional — default is local disk) ===
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-service-role-key
STORAGE_MODE=local
